# ─── DATABASE ────────────────────────────────────────────────────────────────
# Local PostgreSQL:
DATABASE_URL="postgresql://postgres:password@localhost:5432/autokos"
# Cloud (Neon.tech free tier):
# DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/autokos?sslmode=require"

# ─── NEXT AUTH ───────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-this-with-a-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"
# Production:
# NEXTAUTH_URL="https://yourdomain.com"

# ─── EMAIL (Nodemailer) ───────────────────────────────────────────────────────
# The "from" address shown in all outgoing emails
EMAIL_FROM="AutoKos <noreply@autokos.com>"

# For Gmail (use App Password, not regular password):
# Settings → Security → 2FA → App Passwords → Generate
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-gmail@gmail.com"
EMAIL_SERVER_PASSWORD="your-16-char-app-password"

# For Resend (recommended for production — free 3,000/month):
# EMAIL_SERVER_HOST="smtp.resend.com"
# EMAIL_SERVER_PORT="465"
# EMAIL_SERVER_USER="resend"
# EMAIL_SERVER_PASSWORD="re_your_resend_api_key"

# For Mailgun:
# EMAIL_SERVER_HOST="smtp.mailgun.org"
# EMAIL_SERVER_PORT="587"
# EMAIL_SERVER_USER="postmaster@mg.yourdomain.com"
# EMAIL_SERVER_PASSWORD="your-mailgun-smtp-password"

# Admin email — receives contact form submissions and alert notifications
ADMIN_EMAIL="admin@yourdomain.com"

# ─── APPLICATION ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production:
# NEXT_PUBLIC_APP_URL="https://yourdomain.com"

NODE_ENV="development"

# ─── FILE UPLOADS ─────────────────────────────────────────────────────────────
# Local uploads go to public/uploads/ (already configured)
# For production, consider Cloudinary (free 25GB):
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"
# CLOUDINARY_UPLOAD_PRESET="autokos-uploads"
