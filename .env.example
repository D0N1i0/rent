# ─── DATABASE ────────────────────────────────────────────────────────────────
# Local PostgreSQL:
DATABASE_URL="postgresql://postgres:password@localhost:5432/autokos"
# Cloud (Neon.tech free tier):
# DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/autokos?sslmode=require"
# Supabase (add pooler params for Vercel):
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── NEXT AUTH ───────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="replace-this-with-a-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"
# Production: NEXTAUTH_URL="https://yourdomain.com"

# ─── EMAIL (Nodemailer) ───────────────────────────────────────────────────────
EMAIL_FROM="AutoKos <noreply@autokos.com>"

# Resend (recommended for production — free 3,000 emails/month, best deliverability):
# EMAIL_SERVER_HOST="smtp.resend.com"
# EMAIL_SERVER_PORT="465"
# EMAIL_SERVER_USER="resend"
# EMAIL_SERVER_PASSWORD="re_your_resend_api_key"

# Gmail (App Password — Settings → Security → 2FA → App Passwords):
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-gmail@gmail.com"
EMAIL_SERVER_PASSWORD="your-16-char-app-password"

# Mailgun:
# EMAIL_SERVER_HOST="smtp.mailgun.org"
# EMAIL_SERVER_PORT="587"
# EMAIL_SERVER_USER="postmaster@mg.yourdomain.com"
# EMAIL_SERVER_PASSWORD="your-mailgun-smtp-password"

# Admin email — receives new booking alerts and contact form submissions
ADMIN_EMAIL="admin@yourdomain.com"

# ─── APPLICATION ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: NEXT_PUBLIC_APP_URL="https://yourdomain.com"

NODE_ENV="development"

# ─── STRIPE PAYMENTS ──────────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
# Test mode keys start with sk_test_ and pk_test_
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"

# Webhook secret — get from Stripe Dashboard → Developers → Webhooks → Signing secret
# For local testing: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_signing_secret"

# ─── FILE UPLOADS (Cloudinary) ────────────────────────────────────────────────
# Required for production — car images and booking documents are stored in Cloudinary.
# Free tier: 25 GB storage, 25 GB/month bandwidth. Sign up at cloudinary.com
# Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
